        { "id": "api-route", "kind": "content", "pattern": "\\.(get|post|put|patch|delete)\\s*\\(\\s*['\"]/|router\\.(get|post|put|patch|delete)|app\\.(get|post|put|patch|delete)", "weight": 2, "reason": "HTTP route declaration" },
        { "id": "api-worker", "kind": "content", "pattern": "message consumer|event consumer|queue worker|subscribe\\(|consume\\(|@KafkaListener", "weight": 2, "reason": "headless worker or event consumer" }
      ]
    },
    {
      "id": "cli-sdk",
      "label": "CLI or SDK",
