        { "id": "android-project", "kind": "path", "pattern": "(^|/)AndroidManifest\\.xml$|(^|/)android/app/", "weight": 4, "reason": "Android application project" },
        { "id": "apple-project", "kind": "path", "pattern": "\\.(xcodeproj|xcworkspace)/|project\\.pbxproj$|(^|/)ios/", "weight": 4, "reason": "Apple application project" },
