        { "id": "sdk-tree", "kind": "path", "pattern": "(^|/)(sdk|client|clients|packages/sdk|lib/public)/", "weight": 3, "reason": "consumer SDK source tree" },
        { "id": "cli-package-bin", "kind": "content", "pattern": "['\"]bin['\"]\\s*:|#!/usr/bin/env (node|python|bash|sh)", "weight": 3, "reason": "installable command declaration" },
        { "id": "cli-framework", "kind": "content", "pattern": "commander|yargs|click\\.command|argparse|cobra\\.Command|clap::|System\\.CommandLine", "weight": 3, "reason": "command-line framework" },
        { "id": "sdk-contract", "kind": "content", "pattern": "public (class|interface)|exports\\s*=|module\\.exports|export (class|interface|function)|client library|software development kit", "weight": 1, "reason": "public consumer contract" }
      ]
    },
    {
      "id": "mobile-desktop",
      "label": "Mobile or desktop",
