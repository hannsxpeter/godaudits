        { "id": "native-lifecycle", "kind": "content", "pattern": "applicationDidEnterBackground|onPause\\(|onResume\\(|AppLifecycleState|systemTray|secure storage|Keychain", "weight": 2, "reason": "native lifecycle or platform capability" }
      ]
    },
    {
      "id": "data-ml",
      "label": "Data or ML",
