      ]
    },
    {
      "id": "api-service",
      "label": "API or service",
      "signals": [
        { "id": "api-contract", "kind": "path", "pattern": "(^|/)(openapi|swagger)(\\.[^/]+)?\\.(json|ya?ml)$|\\.proto$", "weight": 4, "reason": "versioned service contract" },
