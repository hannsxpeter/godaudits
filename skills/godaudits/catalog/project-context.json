      "id": "web-application",
      "label": "Web application",
      "signals": [
        { "id": "web-source-tree", "kind": "path", "pattern": "(^|/)(app|pages|src/pages|src/routes|src/components)/.*\\.(js|jsx|ts|tsx|vue|svelte)$", "weight": 3, "reason": "browser UI source tree" },
        { "id": "web-entry", "kind": "path", "pattern": "(^|/)(public|static)/(index\\.html|manifest\\.webmanifest)$", "weight": 3, "reason": "browser entry artifact" },
        { "id": "web-framework-config", "kind": "path", "pattern": "(^|/)(next|vite|astro|svelte|nuxt)\\.config\\.|(^|/)angular\\.json$", "weight": 3, "reason": "web framework configuration" },
        { "id": "web-framework", "kind": "content", "pattern": "react-dom/client|from ['\"]next/|@angular/core|createApp\\(|from ['\"]vue['\"]|from ['\"]svelte", "weight": 3, "reason": "browser framework integration" },
