{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hannsxpeter/godaudits/schemas/corpus.schema.json",
  "title": "godaudits deterministic benchmark corpus",
  "type": "object",
  "required": ["schema_version", "fixtures"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "repo", "expected_archetype", "required_signals", "required_absences"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "repo": { "type": "string", "minLength": 1 },
          "expected_archetype": { "type": "string", "minLength": 1 },
          "expected_project_form": { "type": "string", "minLength": 1 },
          "expected_overlays": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "required_signals": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "forbidden_signals": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "required_absences": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "secret_fragment": { "type": "string" },
          "secret_fragments": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
