{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hannsxpeter/godaudits/schemas/dogfood.schema.json",
  "title": "godaudits external OSS dogfood index",
  "type": "object",
  "required": ["schema_version", "published"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "note": { "type": "string" },
    "published": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "repo_url",
          "repo_commit",
          "license",
          "audited_date",
          "domains",
          "budget",
          "model",
          "harness",
          "artifacts",
          "misses",
          "false_positives"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "repo_url": { "type": "string", "pattern": "^https://github\\.com/" },
          "repo_commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
          "license": { "type": "string", "minLength": 1 },
          "audited_date": { "type": "string", "format": "date" },
          "domains": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "budget": { "enum": ["medium", "full"] },
          "model": {
            "type": "object",
            "required": ["provider", "id", "snapshot"],
            "properties": {
              "provider": { "type": "string", "minLength": 1 },
              "id": { "type": "string", "minLength": 1 },
              "snapshot": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "harness": {
            "type": "object",
            "required": ["name", "version", "config_sha256"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "version": { "type": "string", "minLength": 1 },
              "config_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            },
            "additionalProperties": false
          },
          "artifacts": {
            "type": "object",
            "required": ["evidence", "audit", "report"],
            "properties": {
              "evidence": { "type": "string", "minLength": 1 },
              "audit": { "type": "string", "minLength": 1 },
              "report": { "type": "string", "minLength": 1 },
              "sarif": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "misses": { "type": "integer", "minimum": 0 },
          "false_positives": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
