{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hannsxpeter/godaudits/schemas/accuracy-runs.schema.json",
  "title": "godaudits paired accuracy runs",
  "type": "object",
  "required": ["schema_version", "program_version", "runs"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "program_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "note": { "type": "string" },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pair_id",
          "arm",
          "repo",
          "check",
          "repetition",
          "captured",
          "model",
          "harness",
          "fixture_commit",
          "skill_commit",
          "skill_installed",
          "capabilities",
          "result",
          "artifacts",
          "cost"
        ],
        "properties": {
          "pair_id": { "type": "string", "pattern": "^P-[A-Z0-9-]+$" },
          "arm": { "enum": ["control", "skill"] },
          "repo": { "type": "string", "minLength": 1 },
          "check": { "type": "string", "pattern": "^A-[A-Z]+-[0-9]+$" },
          "repetition": { "type": "integer", "minimum": 1 },
          "captured": { "type": "string", "format": "date" },
          "model": {
            "type": "object",
            "required": ["provider", "id", "snapshot", "snapshot_kind", "catalog_fetched_at"],
            "properties": {
              "provider": { "type": "string", "minLength": 1 },
              "id": { "type": "string", "minLength": 1 },
              "snapshot": { "type": "string", "minLength": 1 },
              "snapshot_kind": { "enum": ["immutable", "service-alias"] },
              "catalog_fetched_at": { "type": "string", "format": "date-time" }
            },
            "additionalProperties": false
          },
          "harness": {
            "type": "object",
            "required": ["name", "version", "config_sha256"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "version": { "type": "string", "minLength": 1 },
              "config_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            },
            "additionalProperties": false
          },
          "fixture_commit": { "type": "string", "minLength": 7 },
          "skill_commit": { "type": ["string", "null"], "minLength": 7 },
          "skill_installed": { "type": "boolean" },
          "capabilities": {
            "type": "array",
            "minItems": 1,
            "items": { "enum": ["static", "sandbox", "connected"] },
            "uniqueItems": true
          },
          "result": {
            "type": "object",
            "required": [
              "outcome",
              "hits",
              "misses",
              "false_positives",
              "severity_matches",
              "severity_mismatches",
              "citation_matches",
              "citation_mismatches"
            ],
            "properties": {
              "outcome": { "enum": ["pass", "fail", "unknown"] },
              "hits": { "type": "integer", "minimum": 0 },
              "misses": { "type": "integer", "minimum": 0 },
              "false_positives": { "type": "integer", "minimum": 0 },
              "severity_matches": { "type": "integer", "minimum": 0 },
              "severity_mismatches": { "type": "integer", "minimum": 0 },
              "citation_matches": { "type": "integer", "minimum": 0 },
              "citation_mismatches": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": false
          },
          "artifacts": {
            "type": "object",
            "required": ["audit"],
            "properties": {
              "audit": { "type": "string", "minLength": 1 },
              "transcript": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "cost": {
            "type": "object",
            "required": ["input_tokens", "output_tokens", "elapsed_ms"],
            "properties": {
              "input_tokens": { "type": ["integer", "null"], "minimum": 0 },
              "output_tokens": { "type": ["integer", "null"], "minimum": 0 },
              "elapsed_ms": { "type": ["integer", "null"], "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
